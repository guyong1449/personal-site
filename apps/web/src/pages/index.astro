---
import { loadNoteIndex } from "../lib/content.js";

const notes = await loadNoteIndex();
const featuredNote = notes[0] ?? null;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Personal Site Preview</title>
    <style>
      :root {
        --bg: #f4efe6;
        --panel: rgba(255, 251, 245, 0.94);
        --ink: #231c18;
        --line: #d8cab7;
        --accent: #8f4b24;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(177, 126, 81, 0.14), transparent 28%),
          linear-gradient(180deg, #fbf7f0 0%, var(--bg) 100%);
      }
      main {
        max-width: 1040px;
        margin: 0 auto;
        padding: 40px 20px 72px;
      }
      .hero {
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--panel);
        box-shadow: 0 12px 36px rgba(77, 51, 25, 0.08);
      }
      h1 {
        margin: 0 0 8px;
        font-size: clamp(2.2rem, 5vw, 4rem);
      }
      .hero p {
        max-width: 720px;
        margin: 0;
        line-height: 1.7;
      }
      .meta {
        margin-top: 14px;
        color: var(--accent);
        font-size: 0.95rem;
      }
      .grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 18px;
        margin-top: 24px;
      }
      .panel {
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--panel);
        padding: 24px;
      }
      .note-list {
        display: grid;
        gap: 12px;
      }
      .note-card {
        display: block;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        text-decoration: none;
        color: inherit;
        background: rgba(255, 255, 255, 0.66);
      }
      .note-card:hover {
        border-color: var(--accent);
      }
      .note-card h2 {
        margin: 0 0 8px;
        font-size: 1.15rem;
      }
      .note-card p {
        margin: 0;
        line-height: 1.6;
      }
      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
      }
      .pill {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 0.82rem;
      }
      ol {
        margin: 0;
        padding-left: 20px;
        line-height: 1.8;
      }
      a {
        color: var(--accent);
      }
      @media (max-width: 820px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <h1>Personal Site Preview</h1>
        <p>
          这是给正式前端接入前用的最小预览站。它直接读取
          <code>content/public</code> 里的导出结果，所以你现在看到的结构就是发布脚本真实产物的消费方式。
        </p>
        {featuredNote && (
          <div class="meta">
            当前已导出 {notes.length} 篇笔记，示例入口：
            <a href={`/notes/${featuredNote.slug}`}>{featuredNote.title}</a>
          </div>
        )}
      </section>

      <section class="grid">
        <section class="panel">
          <h2>公开笔记</h2>
          <div class="note-list">
            {notes.length > 0 ? (
              notes.map((note) => (
                <a class="note-card" href={`/notes/${note.slug}`}>
                  <h2>{note.title}</h2>
                  <p>{note.summary || "暂无摘要。"}</p>
                  {note.tags?.length > 0 && (
                    <div class="pill-row">
                      {note.tags.map((tag) => (
                        <span class="pill">{tag}</span>
                      ))}
                    </div>
                  )}
                </a>
              ))
            ) : (
              <p>还没有可预览的公开笔记。先跑一次 publisher 导出内容即可。</p>
            )}
          </div>
        </section>

        <aside class="panel">
          <h2>当前链路</h2>
          <ol>
            <li>你在 Obsidian Vault 里写作，并用 frontmatter 标记 `publish: true`。</li>
            <li>`tools/publisher` 读取 Vault，过滤公开内容，复制图片，重写站内链接。</li>
            <li>导出物进入 `content/public`，前端和 Astro 都只消费这一层。</li>
            <li>Astro 构建静态页面，最后由 Vercel 托管。</li>
          </ol>
        </aside>
      </section>
    </main>
  </body>
</html>
